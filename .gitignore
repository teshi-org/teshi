# Rust build artifacts
target/

# Local Cargo cache (e.g. sandboxed CARGO_HOME under the repo)
.cargo-local/

# Generated by Cargo when using local overrides
**/*.rs.bk

# OS/editor temporary files
.DS_Store
Thumbs.db
*.swp
*.swo

# Cursor: ignore local workspace state, keep shared rules
.cursor/*
!.cursor/rules/
!.cursor/rules/*.mdc

# Codex: local rule copies (canonical copy is under .cursor/rules/)
.codex/

# Local runner config (machine-specific paths); see teshi.toml.example
teshi.toml

# Keep Cargo.lock tracked by default.
# If this repository is a library and you explicitly want to ignore it, uncomment:
# Cargo.lock

# Added by cargo

/target
